{
  "name": "agent-context-trail",
  "displayName": "Agent Context Trail",
  "description": "See how one agent conversation's context evolves, prompt by prompt: tokens, cache reuse, and cost for Claude Code, Codex, and GitHub Copilot.",
  "version": "0.1.1",
  "publisher": "vectormind",
  "private": false,
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1E1B4B",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude code",
    "codex",
    "copilot",
    "tokens",
    "cost",
    "cache",
    "context",
    "ai",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VectorMind/agent-context-trail.git"
  },
  "homepage": "https://github.com/VectorMind/agent-context-trail#readme",
  "bugs": {
    "url": "https://github.com/VectorMind/agent-context-trail/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentContextTrail.refresh",
        "title": "Agent Context Trail: Refresh"
      },
      {
        "command": "agentContextTrail.showSummary",
        "title": "Agent Context Trail: Show Conversation Summary (Text)"
      },
      {
        "command": "agentContextTrail.openPanel",
        "title": "Agent Context Trail: Open Conversation Panel"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "node esbuild.js --production && vsce package --no-dependencies -o agent-context-trail.vsix",
    "install:local": "code --install-extension agent-context-trail.vsix --force",
    "reinstall": "npm run package && npm run install:local"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
